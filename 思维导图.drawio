        <mxCell id="UQ1rKEQhp7pWMMgnoCf4-34" parent="WIyWlLk6GJQsqaUBKTNV-1" style="whiteSpace=wrap;html=1;rounded=1;" value="执行executeNode(startNode, variablePool, workflowCallback);&lt;div&gt;从开始节点开始执行链路&lt;/div&gt;" vertex="1">
