        </mxCell>
        <mxCell id="UQ1rKEQhp7pWMMgnoCf4-38" parent="WIyWlLk6GJQsqaUBKTNV-1" style="shape=tapeData;whiteSpace=wrap;html=1;perimeter=ellipsePerimeter;" value="详解" vertex="1">
          <mxGeometry height="80" width="80" x="550" y="1100" as="geometry" />
        </mxCell>
        <mxCell id="UQ1rKEQhp7pWMMgnoCf4-40" parent="WIyWlLk6GJQsqaUBKTNV-1" style="whiteSpace=wrap;html=1;aspect=fixed;align=left;" value="&lt;div style=&quot;&quot;&gt;内部包装一个ttl，里面存储了content上下文，上下文中放入&lt;/div&gt;&lt;div style=&quot;&quot;&gt;flowId（工作流Id，标识一个工作流，前端传入）&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;chatId（对话Id，标识一个对话，前端传入）&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;sId（会话唯一标识，每次调用工作流都会生成一个新的，一个对话中可能会调用多次工作流）&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;workflowCallback&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;&lt;br&gt;&lt;/div&gt;&lt;div style=&quot;&quot;&gt;父线程在创建子线程的时候会复制这个ttl给子线程，因此子线程直接从ttl中就可以得到这些重要信息，不需要在方法参数中传递 。&lt;/div&gt;" vertex="1">
          <mxGeometry height="240" width="240" x="210" y="1020" as="geometry" />
        </mxCell>
        <mxCell id="UQ1rKEQhp7pWMMgnoCf4-45" edge="1" parent="WIyWlLk6GJQsqaUBKTNV-1" source="UQ1rKEQhp7pWMMgnoCf4-42" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" target="UQ1rKEQhp7pWMMgnoCf4-43" value="">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="UQ1rKEQhp7pWMMgnoCf4-42" parent="WIyWlLk6GJQsqaUBKTNV-1" style="shape=tapeData;whiteSpace=wrap;html=1;perimeter=ellipsePerimeter;" value="详解变量池" vertex="1">
          <mxGeometry height="80" width="80" x="270" y="567.5" as="geometry" />
        </mxCell>
        <mxCell id="UQ1rKEQhp7pWMMgnoCf4-43" parent="WIyWlLk6GJQsqaUBKTNV-1" style="whiteSpace=wrap;html=1;aspect=fixed;align=left;" value="变量池中存储的数据的数据结构是两层map&lt;div&gt;第一层map的key是节点id&lt;/div&gt;&lt;div&gt;第一层map的value是另一个map&lt;/div&gt;&lt;div&gt;第二层map的key的变量名，如input&lt;/div&gt;&lt;div&gt;第二层map的value是这个变量的值&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;节点在执行前会从变量池中获取所需的变量；执行结束后会把输出放到变量池中&lt;/div&gt;" vertex="1">
          <mxGeometry height="200" width="200" x="-10" y="507.5" as="geometry" />
        </mxCell>
        <mxCell id="HdBakHR5HpJFvr5biEs5-1" edge="1" parent="WIyWlLk6GJQsqaUBKTNV-1" source="UQ1rKEQhp7pWMMgnoCf4-46" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" target="HdBakHR5HpJFvr5biEs5-0" value="">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="UQ1rKEQhp7pWMMgnoCf4-46" parent="WIyWlLk6GJQsqaUBKTNV-1" style="shape=tapeData;whiteSpace=wrap;html=1;perimeter=ellipsePerimeter;" value="详解AsyncUtil" vertex="1">
          <mxGeometry height="80" width="90" x="90" y="280" as="geometry" />
        </mxCell>
        <mxCell id="HdBakHR5HpJFvr5biEs5-0" parent="WIyWlLk6GJQsqaUBKTNV-1" style="whiteSpace=wrap;html=1;aspect=fixed;align=left;" value="这是一个异步工具类，用来创建子线程。&lt;div&gt;&lt;br&gt;&lt;div&gt;里面封装了已经定义好的线程池和线程工厂，已经可直接调用的超时控制。&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;线程池的队列长度是0，如果核心线程池满了依旧直接创建新的线程。这是个io密集型应用。核心线程数是cpu的个数×2。队列长度为0是因为快速响应、不堆积在内存。&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;如果最大线程池满了直接启动拒绝策略&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;CallerRunsPolicy。这个策略的含义是让调用线程来执行子线程的任务&lt;/span&gt;&lt;/div&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;线程池被ttl封装，以在线程间传递上下文&lt;/span&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="280" width="280" x="-260" y="190" as="geometry" />
        </mxCell>
